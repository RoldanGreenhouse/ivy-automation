# The variables names are setup based on the name of the service running, not the image itself.

# General versions
greenhouse_postgres_general_version=18.1

# docker-compose.auth.yml
greenhouse_version_redis=8.4.0
greenhouse_version_it_tools=2024.10.22-7ca5933
greenhouse_version_pdf_tools=2.10.0
greenhouse_version_noip_sync=3.3.0
greenhouse_version_nginx=1.25.3
greenhouse_version_whoami=latest
greenhouse_version_teamspeak=latest

# docker-compose.auth.yml
greenhouse_version_authentik_postgres=${greenhouse_postgres_general_version}
greenhouse_version_authentik=2026.2.2
greenhouse_version_authentik_server=${greenhouse_version_authentik}
greenhouse_version_authentik_worker=${greenhouse_version_authentik}

# docker-compose.cloud.yml
greenhouse_version_jellyfin=2025120105
greenhouse_version_nextcloud=33.0.2
greenhouse_version_nextcloud-postgres=${greenhouse_postgres_general_version}

# docker-compose.critical.yml
greenhouse_version_ca_server=0.30.2
greenhouse_version_ca_postgres=${greenhouse_postgres_general_version}
greenhouse_version_adguard=v0.107.74

# docker-compose.monitoring.yml
greenhouse_version_rpi_monitor=latest

# docker-compose.proxy.yml
greenhouse_version_traefik=3.6.14

# docker-compose.vpn.yml
greenhouse_version_wireguard=15.1.0

# docker-compose.zero.trust.yml
greenhouse_version_twingate_connector=1.88.0